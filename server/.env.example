# Port to listen on (default: 6894)
PORT=6894

# Directory to store the database and encryption key (default: ./data)
DATA_DIR=./data

# Optional: Override the auto-generated encryption key with your own 32-byte hex string.
# If not set, a key is generated on first run and saved to DATA_DIR/encryption.key.
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=your64hexcharskeyhere
